{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @icproject/hub-api exec npx prisma generate --schema=prisma/schema.prisma && pnpm --filter @icproject/hub-api run build",
  "builds": [
    {
      "src": "apps/hub-api/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "apps/hub-api/prisma/**",
          "node_modules/.prisma/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/hub-api/api/index.ts"
    }
  ]
}

{
  "version": 2,
  "installCommand": "pnpm --filter @icproject/hub-api... install --frozen-lockfile",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "apps/hub-api/dist/**",
          "apps/hub-api/prisma/**",
          "packages/shared/**",
          "packages/risk-contract/**",
          "apps/hub-api/node_modules/@icproject/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}

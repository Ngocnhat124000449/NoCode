{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @icproject/hub-api exec npx prisma generate --schema=prisma/schema.prisma && mkdir -p public",
  "outputDirectory": "public",
  "functions": {
    "apps/hub-api/api/index.ts": {
      "includeFiles": "apps/hub-api/prisma/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/apps/hub-api/api/index.ts" }
  ]
}

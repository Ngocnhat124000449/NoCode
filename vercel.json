{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "mkdir -p public && echo '{}' > public/index.json",
  "outputDirectory": "public",
  "builds": [
    {
      "src": "apps/hub-api/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "apps/hub-api/prisma/**"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/apps/hub-api/api/index.ts" }
  ]
}

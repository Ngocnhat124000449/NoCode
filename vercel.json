{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @icproject/hub-api exec npx prisma generate --schema=prisma/schema.prisma",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "apps/hub-api/prisma/**",
          "apps/hub-api/src/generated/prisma/**"
        ]
      }
    }
  ],
  "rewrites": [
    { "source": "/:path*", "destination": "/api/index" }
  ]
}

{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @icproject/shared build && pnpm --filter @icproject/risk-contract build && pnpm --filter @icproject/hub-api exec npx prisma generate --schema=prisma/schema.prisma",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "apps/hub-api/prisma/**",
          "packages/shared/**",
          "packages/risk-contract/**",
          "apps/hub-api/node_modules/@icproject/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.ts" }
  ]
}

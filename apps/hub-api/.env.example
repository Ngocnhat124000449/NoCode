# === DATABASE (Railway Postgres plugin provides DATABASE_URL automatically) ===
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB"

# === REDIS (Railway Redis plugin provides REDIS_URL automatically) ===
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# === APP ===
PORT=3000
NODE_ENV=production

# === SECURITY — generate with: openssl rand -hex 32 ===
PHONE_HMAC_SECRET="change_me_min_32_chars_hex_string_here"

# === JWT AUTH — generate with: openssl rand -hex 32 ===
JWT_SECRET="change_me_min_32_chars_jwt_secret_here"
JWT_EXPIRES_IN="30d"

# === RISK TOKEN — generate with: openssl rand -hex 64 ===
RISK_TOKEN_SECRET="change_me_min_64_chars_secret_string_here"
RISK_TOKEN_TTL_SECONDS=600

# === OBSERVABILITY (optional) ===
SENTRY_DSN=""
